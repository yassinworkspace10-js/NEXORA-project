<%- include('../partials/header') %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap');

/* ── TOKENS ──────────────────────────────────────────────── */
.pkg-page {
  --ink:        #080d1a;
  --ink2:       #0f1d3a;
  --sky:        #00d4ff;
  --sky2:       #00aacc;
  --violet:     #7b5cf0;
  --violet2:    #5c3fc0;
  --violet3:    #4a2fa8;
  --surface:    #f4f6ff;
  --surface2:   #eef0fc;
  --card:       #ffffff;
  --muted:      #64748b;
  --muted2:     #94a3b8;
  --border:     rgba(123,92,240,.12);
  --border2:    rgba(123,92,240,.22);
  --r:          16px;
  --r2:         24px;
  --sh:         0 4px 24px rgba(0,0,0,.06), 0 1px 4px rgba(0,0,0,.04);
  --shm:        0 8px 40px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.05);
  --shl:        0 20px 60px rgba(0,0,0,.14), 0 4px 16px rgba(0,0,0,.06);
  --glow-sky:   0 0 40px rgba(0,212,255,.25);
  --glow-v:     0 0 40px rgba(123,92,240,.3);
  --trans:      all .3s cubic-bezier(.4,0,.2,1);
  --ease-spring:cubic-bezier(.34,1.56,.64,1);
  --ease-out:   cubic-bezier(.16,1,.3,1);
  font-family: 'DM Sans', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
}
.pkg-page *, .pkg-page *::before, .pkg-page *::after { box-sizing: border-box; }
.pkg-page h1, .pkg-page h2, .pkg-page h3, .pkg-page h4, .pkg-page h5 { font-family: 'Syne', sans-serif; }

/* ── HERO ────────────────────────────────────────────────── */
.pkg-hero {
  position: relative; background: var(--ink);
  padding: 9rem 2rem 8rem; text-align: center; overflow: hidden;
}
.pkg-hero::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 20% 0%,  rgba(123,92,240,.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 50% at 80% 100%,rgba(0,212,255,.14) 0%, transparent 55%),
    radial-gradient(ellipse 40% 70% at 90% 20%,  rgba(123,92,240,.08) 0%, transparent 50%);
  pointer-events: none;
}
.pkg-hero::after {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(123,92,240,.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(123,92,240,.055) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  pointer-events: none;
}
.hero-orb {
  position: absolute; border-radius: 50%; pointer-events: none; filter: blur(80px);
}
.hero-orb-1 { width:480px;height:480px;top:-180px;left:-80px;  background:rgba(123,92,240,.13);animation:orb 12s ease-in-out infinite; }
.hero-orb-2 { width:380px;height:380px;bottom:-140px;right:-60px;background:rgba(0,212,255,.11);animation:orb 15s ease-in-out infinite reverse; }
.hero-orb-3 { width:280px;height:280px;top:35%;left:58%;        background:rgba(123,92,240,.07);animation:orb 10s ease-in-out infinite 3s; }
@keyframes orb {
  0%,100%{transform:translate(0,0) scale(1);}
  33%{transform:translate(28px,-18px) scale(1.07);}
  66%{transform:translate(-18px,14px) scale(.93);}
}
.hero-content { position: relative; z-index: 2; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .35rem 1.1rem; border: 1px solid rgba(0,212,255,.3); border-radius: 999px;
  font-family: 'Syne',sans-serif; font-size: .68rem; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase; color: var(--sky);
  background: rgba(0,212,255,.06); margin-bottom: 1.75rem;
  animation: fade-up .8s var(--ease-out) both;
}
.hero-dot {
  width:6px;height:6px;border-radius:50%;background:var(--sky);
  box-shadow:0 0 8px var(--sky);animation:pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot { 0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.4);opacity:.6;} }
.pkg-hero h1 {
  font-size: clamp(2.8rem,6.5vw,5rem); font-weight: 800;
  letter-spacing: -.04em; line-height: .95; color: #fff; margin-bottom: 1.5rem;
  animation: fade-up .9s .1s var(--ease-out) both;
}
.pkg-hero h1 .grad {
  background: linear-gradient(135deg, var(--sky), var(--violet));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.pkg-hero > .hero-content > p {
  font-size: 1.05rem; color: rgba(255,255,255,.5); max-width: 480px;
  margin: 0 auto; line-height: 1.8; animation: fade-up .9s .2s var(--ease-out) both;
}
.hero-scroll {
  position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
  z-index: 2; display: flex; flex-direction: column; align-items: center; gap: .4rem;
  opacity: .3; animation: fade-up .9s .5s var(--ease-out) both;
}
.hero-scroll span { font-size:.62rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#fff; }
.scroll-track {
  width:1px;height:40px;
  background:linear-gradient(to bottom,rgba(0,212,255,.8),transparent);
  animation:track-drop 2.2s ease-in-out infinite;transform-origin:top;
}
@keyframes track-drop{0%{transform:scaleY(0);opacity:0;}30%{opacity:1;}70%{transform:scaleY(1);opacity:1;}100%{transform:scaleY(1);opacity:0;}}
@keyframes fade-up{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}

/* ── PRICING ─────────────────────────────────────────────── */
.pricing-wrap {
  background: var(--surface); padding: 6rem 2rem 7rem;
  position: relative; overflow: hidden;
}
.pricing-wrap::before {
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--violet),var(--sky),var(--violet),transparent);
}
.pricing-wrap::after {
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 55% 40% at 10% 80%,rgba(123,92,240,.06) 0%,transparent 60%),
    radial-gradient(ellipse 45% 50% at 90% 20%,rgba(0,212,255,.05) 0%,transparent 60%);
  pointer-events:none;
}
.pricing-inner { max-width:1160px;margin:0 auto;position:relative;z-index:1; }
.pricing-grid {
  display:grid;grid-template-columns:1fr 1.05fr 1fr;gap:1.5rem;align-items:start;
}

/* card */
.p-card {
  position:relative;background:var(--card);border:1.5px solid var(--border);
  border-radius:var(--r2);padding:2.25rem 2rem;box-shadow:var(--sh);
  transition:var(--trans);overflow:hidden;opacity:0;transform:translateY(28px);
}
.p-card.vis { animation:card-rise .65s var(--ease-out) forwards; }
.p-card:nth-child(1).vis{animation-delay:0s;}
.p-card:nth-child(2).vis{animation-delay:.12s;}
.p-card:nth-child(3).vis{animation-delay:.22s;}
@keyframes card-rise{to{opacity:1;transform:translateY(0);}}
.p-card::before {
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--violet),transparent);
  opacity:0;transition:opacity .3s;
}
.p-card:hover::before{opacity:1;}
.p-card::after {
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 50% at 50% 0%,rgba(123,92,240,.04) 0%,transparent 70%);
  opacity:0;transition:opacity .4s;pointer-events:none;
}
.p-card:hover::after{opacity:1;}
.p-card:hover{box-shadow:var(--shm);border-color:var(--border2);transform:translateY(-6px);}

/* featured */
.p-card.featured {
  background:linear-gradient(155deg,var(--ink2),var(--ink));
  border-color:rgba(123,92,240,.35);
  box-shadow:var(--shl),var(--glow-v);
  transform:translateY(-10px);z-index:2;
}
.p-card.featured::before {
  background:linear-gradient(90deg,transparent,var(--sky),var(--violet),var(--sky),transparent);
  background-size:300% 100%;opacity:1;
  animation:shimmer-top 3s linear infinite;
}
@keyframes shimmer-top{0%{background-position:150% 0;}100%{background-position:-150% 0;}}
.p-card.featured::after{
  background:radial-gradient(ellipse 80% 50% at 50% 0%,rgba(0,212,255,.07) 0%,transparent 70%);
  opacity:1;
}
.p-card.featured:hover{
  transform:translateY(-18px);
  box-shadow:0 40px 100px rgba(0,0,0,.25),var(--glow-v),var(--glow-sky);
  border-color:rgba(0,212,255,.4);
}

.feat-badge {
  display:inline-flex;align-items:center;gap:.4rem;
  padding:.3rem .9rem;
  background:linear-gradient(135deg,var(--violet),var(--violet2));
  color:#fff;font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;border-radius:999px;
  margin-bottom:1.5rem;box-shadow:var(--glow-v);
}
.pkg-tier {
  font-family:'Syne',sans-serif;font-size:.63rem;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--muted2);margin-bottom:.5rem;
}
.p-card.featured .pkg-tier{color:rgba(0,212,255,.6);}
.pkg-name {
  font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;
  letter-spacing:-.04em;line-height:1;color:var(--ink);margin-bottom:1.1rem;
}
.p-card.featured .pkg-name{
  background:linear-gradient(135deg,var(--sky),var(--violet));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.pkg-price{
  font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:700;
  letter-spacing:-.03em;color:var(--violet);
}
.p-card.featured .pkg-price{color:var(--sky);}
.pkg-del{
  font-size:.74rem;color:var(--muted2);margin-top:.3rem;
  display:flex;align-items:center;gap:.3rem;
}
.p-card.featured .pkg-del{color:rgba(255,255,255,.35);}
.pkg-divider{height:1px;background:var(--border);margin:1.4rem 0;}
.p-card.featured .pkg-divider{background:rgba(123,92,240,.25);}
.pkg-desc{font-size:.84rem;color:var(--muted);line-height:1.75;margin-bottom:1.5rem;}
.p-card.featured .pkg-desc{color:rgba(255,255,255,.5);}

.pkg-feats{list-style:none;padding:0;margin:0 0 2rem;display:flex;flex-direction:column;gap:.6rem;}
.pkg-feats li{
  display:flex;align-items:center;gap:.65rem;
  font-size:.82rem;color:var(--muted);line-height:1.4;
}
.pkg-feats li::before{
  content:'';flex-shrink:0;width:18px;height:18px;border-radius:50%;
  border:1.5px solid var(--border2);background:rgba(123,92,240,.05);
  background-image:url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%237b5cf0' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat:no-repeat;background-position:center;
}
.p-card.featured .pkg-feats li{color:rgba(255,255,255,.65);}
.p-card.featured .pkg-feats li::before{
  border-color:rgba(0,212,255,.4);background-color:rgba(0,212,255,.07);
  background-image:url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%2300d4ff' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
}
.pkg-btn{
  display:block;width:100%;text-align:center;padding:.875rem 1.5rem;border-radius:var(--r);
  font-family:'Syne',sans-serif;font-size:.82rem;font-weight:700;letter-spacing:.03em;
  text-decoration:none;border:none;cursor:pointer;transition:var(--trans);
}
.pkg-btn:hover{transform:translateY(-2px);}
.pkg-btn:active{transform:translateY(0) scale(.98);}
.btn-sky{background:linear-gradient(135deg,var(--sky),var(--sky2));color:var(--ink);font-weight:800;box-shadow:0 4px 20px rgba(0,212,255,.3);}
.btn-sky:hover{box-shadow:var(--glow-sky),0 8px 32px rgba(0,212,255,.25);}
.btn-violet{background:linear-gradient(135deg,var(--violet),var(--violet2));color:#fff;box-shadow:0 4px 20px rgba(123,92,240,.35);}
.btn-violet:hover{box-shadow:0 8px 32px rgba(123,92,240,.5);}
.btn-ghost{background:transparent;border:1.5px solid var(--border2);color:var(--violet);}
.btn-ghost:hover{border-color:var(--violet);background:rgba(123,92,240,.05);box-shadow:var(--glow-v);}

/* ── PAYMENT ─────────────────────────────────────────────── */
.payment-wrap{
  background:var(--ink);padding:6rem 2rem;position:relative;overflow:hidden;
}
.payment-wrap::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 50% 70% at 0% 50%,  rgba(123,92,240,.12) 0%,transparent 60%),
    radial-gradient(ellipse 40% 60% at 100% 30%, rgba(0,212,255,.09) 0%,transparent 55%),
    radial-gradient(ellipse 60% 40% at 50% 100%, rgba(123,92,240,.06) 0%,transparent 55%);
  pointer-events:none;
}
.payment-wrap::after{
  content:'';position:absolute;inset:0;
  background-image:linear-gradient(rgba(123,92,240,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(123,92,240,.04) 1px,transparent 1px);
  background-size:64px 64px;pointer-events:none;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black,transparent);
  -webkit-mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,black,transparent);
}
.payment-inner{max-width:1100px;margin:0 auto;position:relative;z-index:1;}
.payment-grid{display:grid;grid-template-columns:1fr 270px;gap:5rem;align-items:center;}

.tag-dark{
  display:inline-flex;align-items:center;gap:.5rem;padding:.3rem 1rem;
  border:1px solid rgba(0,212,255,.25);border-radius:999px;
  font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:.14em;text-transform:uppercase;color:var(--sky);
  background:rgba(0,212,255,.06);margin-bottom:1.25rem;
}
.payment-title{
  font-family:'Syne',sans-serif;font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;
  letter-spacing:-.04em;line-height:1.1;color:#fff;margin-bottom:1rem;
}
.payment-title .accent{
  background:linear-gradient(135deg,var(--sky),var(--violet));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.payment-desc{
  font-size:.95rem;color:rgba(255,255,255,.45);line-height:1.85;max-width:500px;margin-bottom:2.5rem;
}
.payment-desc strong{color:rgba(255,255,255,.8);font-weight:600;}
.steps{display:flex;flex-direction:column;gap:.7rem;}
.step{
  display:flex;gap:1.1rem;align-items:flex-start;
  padding:1.1rem 1.35rem;background:rgba(255,255,255,.03);
  border:1px solid rgba(123,92,240,.14);border-radius:var(--r);
  transition:var(--trans);position:relative;overflow:hidden;
}
.step::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:2px;
  background:linear-gradient(to bottom,var(--sky),var(--violet));
  transform:scaleY(0);transform-origin:bottom;transition:transform .35s var(--ease-out);
}
.step:hover::before{transform:scaleY(1);}
.step:hover{background:rgba(255,255,255,.055);border-color:rgba(123,92,240,.3);transform:translateX(6px);box-shadow:0 8px 30px rgba(0,0,0,.2);}
.step-num{
  flex-shrink:0;width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,var(--violet),var(--violet2));
  color:#fff;font-family:'Syne',sans-serif;font-size:.78rem;font-weight:800;
  display:flex;align-items:center;justify-content:center;box-shadow:0 4px 14px rgba(123,92,240,.4);
}
.step-body h5{font-family:'Syne',sans-serif;font-size:.87rem;font-weight:700;color:#fff;margin:0 0 .2rem;}
.step-body p{font-size:.78rem;color:rgba(255,255,255,.38);line-height:1.55;margin:0;}

/* VF card */
.vf-wrap{display:flex;justify-content:center;align-items:center;}
.vf-card{
  position:relative;width:245px;padding:2.5rem 1.75rem;
  background:rgba(255,255,255,.04);border:1.5px solid rgba(123,92,240,.25);
  border-radius:var(--r2);box-shadow:var(--shl),var(--glow-v);
  text-align:center;display:flex;flex-direction:column;align-items:center;gap:.85rem;
  overflow:hidden;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  transition:transform .5s var(--ease-spring),box-shadow .5s var(--ease-out);
}
.vf-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--violet3),#e60000,#ff6666,#e60000,var(--violet3));
  background-size:300% 100%;animation:vf-stripe 2.8s linear infinite;
}
@keyframes vf-stripe{0%{background-position:150% 0;}100%{background-position:-150% 0;}}
.vf-card::after{
  content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);
  width:200px;height:200px;
  background:radial-gradient(circle,rgba(230,0,0,.1) 0%,transparent 70%);pointer-events:none;
}
.vf-card:hover{transform:translateY(-10px) scale(1.02);box-shadow:0 40px 90px rgba(0,0,0,.4),0 0 0 1px rgba(230,0,0,.25),var(--glow-v);border-color:rgba(230,0,0,.3);}
.vf-logo{width:140px;height:auto;object-fit:contain;display:block;margin:0 auto;position:relative;z-index:1;}
.vf-fallback{display:none;flex-direction:column;align-items:center;gap:.6rem;position:relative;z-index:1;}
.vf-icon-circle{width:72px;height:72px;border-radius:50%;background:rgba(230,0,0,.1);border:1px solid rgba(230,0,0,.25);display:flex;align-items:center;justify-content:center;}
.vf-fallback-name{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:800;color:#e60000;letter-spacing:-.02em;}
.vf-sep{width:100%;height:1px;background:rgba(123,92,240,.2);position:relative;z-index:1;}
.vf-label{font-family:'Syne',sans-serif;font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.3);position:relative;z-index:1;}
.vf-sub{font-size:.7rem;color:rgba(255,255,255,.35);padding:.28rem .85rem;background:rgba(255,255,255,.05);border:1px solid rgba(123,92,240,.2);border-radius:999px;white-space:nowrap;position:relative;z-index:1;}

/* ── COMPARE ─────────────────────────────────────────────── */
.compare-wrap{background:var(--surface2);padding:6rem 2rem;position:relative;overflow:hidden;}
.compare-wrap::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--violet),var(--sky),var(--violet),transparent);
}
.compare-inner{max-width:900px;margin:0 auto;position:relative;z-index:1;}
.sec-eyebrow{
  display:inline-flex;align-items:center;gap:.5rem;padding:.3rem 1rem;
  border:1px solid var(--border2);border-radius:999px;
  font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:.14em;text-transform:uppercase;color:var(--violet);
  background:rgba(123,92,240,.05);margin-bottom:1rem;
}
.sec-head{margin-bottom:3rem;}
.sec-head h2{
  font-family:'Syne',sans-serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:800;
  letter-spacing:-.04em;color:var(--ink);margin-bottom:.6rem;
}
.sec-head p{font-size:.9rem;color:var(--muted);max-width:460px;line-height:1.7;}
.sec-head h2.light{color:#fff;}
.sec-head p.light{color:rgba(255,255,255,.42);}

.tbl-outer{border-radius:var(--r2);overflow:hidden;border:1.5px solid var(--border2);box-shadow:var(--shl);background:var(--card);}
.compare-tbl{width:100%;border-collapse:collapse;}
.compare-tbl thead tr{background:linear-gradient(135deg,var(--ink2),var(--ink));}
.compare-tbl thead th{
  padding:1.1rem 1.5rem;font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.45);text-align:center;
}
.compare-tbl thead th:first-child{text-align:left;color:rgba(255,255,255,.65);}
/* featured column */
.compare-tbl thead th.th-feat{background:rgba(0,212,255,.08);color:var(--sky);}
.compare-tbl tbody tr{border-bottom:1px solid var(--border);transition:background .18s;}
.compare-tbl tbody tr:last-child{border-bottom:none;}
.compare-tbl tbody tr:hover{background:var(--surface);}
.compare-tbl tbody td{padding:1rem 1.5rem;font-size:.83rem;color:var(--muted2);text-align:center;}
.compare-tbl tbody td:first-child{text-align:left;color:var(--ink);font-weight:500;}
.compare-tbl tbody td.td-feat{background:rgba(123,92,240,.03);}
.chk{color:var(--violet);font-size:1.05rem;font-weight:700;}
.crs{color:var(--muted2);opacity:.4;}

/* ── FAQ ─────────────────────────────────────────────────── */
.faq-wrap{background:var(--surface);padding:6rem 2rem;position:relative;overflow:hidden;}
.faq-wrap::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 55% 50% at 100% 0%,rgba(0,212,255,.05) 0%,transparent 55%);
  pointer-events:none;
}
.faq-inner{max-width:900px;margin:0 auto;position:relative;z-index:1;}
.faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem;margin-top:3rem;}
.faq-card{
  padding:1.75rem;background:var(--card);border:1.5px solid var(--border);
  border-radius:var(--r2);box-shadow:var(--sh);position:relative;overflow:hidden;transition:var(--trans);
}
.faq-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--violet),var(--sky));
  transform:scaleX(0);transform-origin:left;transition:transform .35s var(--ease-out);
}
.faq-card:hover::before{transform:scaleX(1);}
.faq-card:hover{border-color:var(--border2);box-shadow:var(--shm);transform:translateY(-5px);}
.faq-card h4{font-family:'Syne',sans-serif;font-size:.93rem;font-weight:700;color:var(--ink);margin-bottom:.7rem;letter-spacing:-.01em;}
.faq-card p{font-size:.82rem;color:var(--muted);line-height:1.75;margin:0;}
.faq-card p strong{color:var(--ink);font-weight:600;}

/* ── BOTTOM CTA ──────────────────────────────────────────── */
.pkg-cta{
  background:var(--ink);padding:7rem 2rem;text-align:center;position:relative;overflow:hidden;
}
.pkg-cta::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 60% at 50% 120%,rgba(123,92,240,.18) 0%,transparent 60%),radial-gradient(ellipse 40% 40% at 20% 20%,rgba(0,212,255,.07) 0%,transparent 55%);
  pointer-events:none;
}
.pkg-cta::after{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(123,92,240,.4),rgba(0,212,255,.4),rgba(123,92,240,.4),transparent);
}
.cta-inner{position:relative;z-index:1;max-width:560px;margin:0 auto;}
.cta-inner h2{
  font-family:'Syne',sans-serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:800;
  letter-spacing:-.05em;line-height:.95;color:#fff;margin-bottom:1.25rem;
}
.cta-inner h2 .grad{
  background:linear-gradient(135deg,var(--sky),var(--violet));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.cta-inner p{font-size:.96rem;color:rgba(255,255,255,.4);line-height:1.8;margin-bottom:2.5rem;}
.cta-link{
  display:inline-flex;align-items:center;gap:.6rem;padding:1rem 2.2rem;
  background:linear-gradient(135deg,var(--violet),var(--violet2));color:#fff;
  border-radius:var(--r);font-family:'Syne',sans-serif;font-size:.88rem;font-weight:800;
  letter-spacing:.03em;text-decoration:none;
  box-shadow:var(--glow-v),0 8px 32px rgba(123,92,240,.3);transition:var(--trans);
}
.cta-link:hover{transform:translateY(-4px);box-shadow:var(--glow-v),var(--glow-sky),0 16px 48px rgba(123,92,240,.35);}
.cta-link .arr{display:inline-block;transition:transform .3s var(--ease-spring);}
.cta-link:hover .arr{transform:translateX(5px);}

/* ── SCROLL REVEAL ───────────────────────────────────────── */
.sr{opacity:0;transform:translateY(24px);transition:opacity .65s var(--ease-out),transform .65s var(--ease-out);}
.sr.on{opacity:1;transform:translateY(0);}
.sr[data-d="1"]{transition-delay:.1s;}
.sr[data-d="2"]{transition-delay:.2s;}
.sr[data-d="3"]{transition-delay:.3s;}
.sr[data-d="4"]{transition-delay:.4s;}

/* ── RESPONSIVE ──────────────────────────────────────────── */
@media(max-width:1040px){
  .pricing-grid{grid-template-columns:1fr 1fr;}
  .p-card:last-child{grid-column:1/-1;max-width:460px;margin:0 auto;width:100%;}
}
@media(max-width:820px){
  .payment-grid{grid-template-columns:1fr;gap:3rem;}
  .vf-wrap{justify-content:flex-start;}
  .faq-grid{grid-template-columns:1fr;}
}
@media(max-width:660px){
  .pricing-grid{grid-template-columns:1fr;}
  .p-card:last-child{grid-column:auto;max-width:100%;}
  .p-card.featured{transform:none;}
  .vf-card{width:100%;max-width:280px;}
  .compare-tbl thead th,.compare-tbl tbody td{padding:.8rem .75rem;font-size:.76rem;}
}
@media(max-width:460px){
  .pricing-wrap,.payment-wrap,.compare-wrap,.faq-wrap,.pkg-cta{padding-left:1.25rem;padding-right:1.25rem;}
}
